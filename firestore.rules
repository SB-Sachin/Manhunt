rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      // Anyone authenticated (anonymous) can read a game
      allow read: if request.auth != null;

      // Create: must be authenticated, setting themselves as host
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Update: allow joining any game that hasn't ended, or any existing player
      // updating during play
      allow update: if request.auth != null
        && (
          // Joining (lobby OR late, mid-game) — only add yourself to players,
          // don't remove anyone, don't touch other fields, game not over.
          (resource.data.status != 'GAME_OVER'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])
            && request.resource.data.players.keys().hasAll(resource.data.players.keys())
            && !(request.auth.uid in resource.data.players)
            && request.resource.data.players[request.auth.uid].id == request.auth.uid)
          ||
          // In-game: user is already a player
          request.auth.uid in resource.data.players
        );
    }

    // Per-user stats. Readable by any signed-in user (for the leaderboard — the
    // doc holds only a nickname + game counts, no email/PII). Writable only by
    // the owner.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
