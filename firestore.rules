rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      // Anyone authenticated (anonymous) can read a game
      allow read: if request.auth != null;

      // Create: must be authenticated, setting themselves as host
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Update: allow joining a LOBBY game, or any existing player updating during play
      allow update: if request.auth != null
        && (
          // Joining: game is in LOBBY and user is only adding themselves to players
          (resource.data.status == 'LOBBY'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])
            && request.resource.data.players.keys().hasAll(resource.data.players.keys()))
          ||
          // In-game: user is already a player
          request.auth.uid in resource.data.players
        );
    }

    // Per-user stats — readable/writable only by that user
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
